{
  "name": "@superflag-sh/react",
  "version": "0.6.0",
  "description": "React SDK for Superflag feature flags (web only)",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/esm/index.js",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superflag-sh/react.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "feature-flags",
    "react",
    "superflag"
  ],
  "author": "Superflag",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@superflag-sh/core": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./src/__tests__",
    "test:watch": "bun test --watch ./src/__tests__",
    "check:cache-drift": "node scripts/check-cache-drift.mjs",
    "smoke:package": "node scripts/smoke-package.mjs",
    "smoke:registry": "node scripts/smoke-registry.mjs",
    "release:check": "bun run test && bun run typecheck && bun run check:cache-drift && bun run build && bun run smoke:package",
    "prepack": "bun run build",
    "prepublishOnly": "bun run release:check"
  }
}
