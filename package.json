{
  "name": "@superflag-sh/react",
  "version": "0.4.1",
  "description": "React SDK for Superflag feature flags (web only)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/superflag-sh/react"
  },
  "keywords": [
    "feature-flags",
    "react",
    "superflag"
  ],
  "author": "Superflag",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --outdir dist --format esm --external react && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  }
}
